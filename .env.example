# Discord webhook URL (Server Settings -> Integrations -> Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/xxxxx

# Optional: shared secret to include in TradingView alert JSON body,
# so random requests to your webhook URL are rejected.
WEBHOOK_SECRET=change_me_to_something_random

# Stop loss / take profit defaults, as % of option premium
DEFAULT_STOP_PCT=30
DEFAULT_TARGET_PCT=50

# Local port for Flask
PORT=5000
